rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: only the owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Workouts: owner can read/write, connected users can read
    match /workouts/{workoutId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && request.auth.uid == resource.data.userId
        || (request.auth != null && request.resource.data.userId == request.auth.uid);
    }

    // Connections: involved users can read, owner can create, both can delete
    match /connections/{connectionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.ownerId == request.auth.uid || resource.data.buddyId == request.auth.uid);
      allow delete: if request.auth != null
        && (resource.data.ownerId == request.auth.uid || resource.data.buddyId == request.auth.uid);
    }
  }
}
